<?xml version="1.0" encoding="utf-8"?>
<com.hedvig.app.ui.view.HedvigCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/perilCard"
    android:layout_width="120dp"
    android:layout_height="120dp"
    android:layout_marginStart="@dimen/base_margin_half"
    android:layout_marginEnd="@dimen/base_margin_half"
    android:orientation="vertical"
    android:padding="@dimen/base_margin_double">

    <TextView
        android:id="@+id/peril"
        style="@style/Body.Small"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/base_margin"
        android:drawableTop="@drawable/ic_fire_red"
        android:drawablePadding="@dimen/base_margin"
        android:gravity="center_horizontal"
        tools:text="Eldsvåda" />

</com.hedvig.app.ui.view.HedvigCardView>